{% for vrf in vrfs %}
vrf instance {{ name }}
ip routing vrf {{ name }}

router bgp {{ asn }}
   vrf {{ name }}
      rd {{ rd }}
      route-target import evpn {{ import_rt}}
      route-target export evpn {{ export_rt}}
      redistribute connected

interface Vxlan1
   vxlan vrf {{ name }} vni {{ l3vni }}
!
{% endfor %}

